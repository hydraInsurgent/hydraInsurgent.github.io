---
import { getCollection } from 'astro:content';
import SiteLayout from '../../layouts/SiteLayout.astro';

const posts = (await getCollection('tech')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
---

<SiteLayout title="Tech" description="Technical writing - tutorials, dev notes, learnings.">
  <header class="glass-panel p-7 sm:p-10">
    <span class="eyebrow">Tech</span>
    <div class="section-heading mt-6">
      <div>
        <h1 class="section-title">Tutorials, notes, and things I've figured out.</h1>
        <p class="section-copy mt-4">
          A running archive of practical lessons, technical deep-dives, and write-ups that turn problem solving into something reusable.
        </p>
      </div>
      <p class="text-sm font-medium uppercase tracking-[0.2em] text-slate-400">{posts.length} posts</p>
    </div>
  </header>

  <ul class="mt-8 grid gap-5">
    {posts.map((post) => {
      const formattedDate = post.data.date.toLocaleDateString('en-US', {
        year: 'numeric',
        month: 'long',
        day: 'numeric',
      });

      return (
        <li>
          <a href={`/tech/${post.id}`} class="content-card block">
            <p class="meta-kicker">Technical note</p>
            <h2 class="mt-4 text-3xl">{post.data.title}</h2>
            <p class="mt-3 text-sm text-slate-600">{post.data.description}</p>
            <time class="mt-6 block text-xs font-medium uppercase tracking-[0.2em] text-slate-400" datetime={post.data.date.toISOString()}>
              {formattedDate}
            </time>
          </a>
        </li>
      );
    })}
  </ul>
</SiteLayout>
