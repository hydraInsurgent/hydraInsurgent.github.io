---
// Individual tech post page.
// Astro uses getStaticPaths() to pre-generate one page per post at build time.
import { getCollection, render } from 'astro:content';
import PostLayout from '../../layouts/PostLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('tech');
  // Return one path object per post - Astro generates a page for each
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;

// render() converts the Markdown body into HTML and provides the <Content> component
const { Content } = await render(post);
---

<PostLayout
  title={post.data.title}
  description={post.data.description}
  date={post.data.date}
>
  <Content />
</PostLayout>
