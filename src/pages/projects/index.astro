---
import { getCollection } from 'astro:content';
import SiteLayout from '../../layouts/SiteLayout.astro';

const projects = (await getCollection('projects')).sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<SiteLayout title="Projects" description="Things I've built.">
  <header class="glass-panel p-7 sm:p-10">
    <span class="eyebrow">Projects</span>
    <div class="section-heading mt-6">
      <div>
        <h1 class="section-title">Things I've built.</h1>
        <p class="section-copy mt-4">
          A curated view of work that deserves a public home, from the site itself to the next experiments taking shape.
        </p>
      </div>
      <p class="text-sm font-medium uppercase tracking-[0.2em] text-slate-400">{projects.length} entries</p>
    </div>
  </header>

  <ul class="mt-8 grid gap-5 md:grid-cols-2">
    {projects.map((project) => (
      <li class="min-w-0">
        <a
          href={project.data.url}
          target="_blank"
          rel="noopener noreferrer"
          class="content-card block h-full"
        >
          <div class="flex items-start justify-between gap-4 overflow-hidden">
            <div class="min-w-0">
              <p class="meta-kicker">Project</p>
              <h2 class="mt-4 text-3xl">{project.data.title}</h2>
            </div>
            <span class="shrink-0 rounded-full bg-slate-100 px-3 py-1 text-xs font-semibold uppercase tracking-[0.18em] text-slate-500">
              External
            </span>
          </div>
          <p class="mt-3 text-sm text-slate-600">{project.data.description}</p>
        </a>
      </li>
    ))}
  </ul>
</SiteLayout>
