---
// Projects listing page.
// Projects link out externally - no individual project pages in v1.
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

// Projects have no date so we just display them in filesystem order
const projects = await getCollection('projects');
---

<BaseLayout title="Projects" description="Things I've built.">
  <header class="mb-10">
    <h1 class="text-2xl font-semibold text-ink mb-2">Projects</h1>
    <p class="text-gray-400 text-sm">Things I've built.</p>
  </header>

  <ul class="space-y-8">
    {projects.map((project) => (
      <li>
        <a
          href={project.data.url}
          target="_blank"
          rel="noopener noreferrer"
          class="group block"
        >
          <div class="flex items-baseline justify-between">
            <h2 class="font-medium text-ink group-hover:text-gray-500 transition-colors">
              {project.data.title}
            </h2>
            <!-- External link indicator -->
            <span class="text-xs text-gray-300 group-hover:text-gray-400 transition-colors ml-2 shrink-0">
              ↗
            </span>
          </div>
          <p class="text-sm text-gray-400 mt-1">{project.data.description}</p>
        </a>
      </li>
    ))}
  </ul>
</BaseLayout>
