---
import SiteLayout from './SiteLayout.astro';

interface Props {
  title: string;
  description: string;
  date: Date;
  ogImage?: string;
  liveDemo?: string;
}

const { title, description, date, ogImage, liveDemo } = Astro.props;

const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<SiteLayout title={title} description={description} ogImage={ogImage}>
  <article class="glass-panel overflow-hidden p-7 sm:p-10">
    <header class="mb-10 border-b border-slate-200/80 pb-8">
      <span class="eyebrow mb-5">Field notes</span>
      <h1 class="max-w-3xl text-4xl sm:text-5xl">{title}</h1>
      <div class="mt-4 flex items-start justify-between gap-6">
        <p class="max-w-2xl text-base text-slate-600">{description}</p>
        {liveDemo && (
          <a href={liveDemo} target="_blank" rel="noreferrer" class="nav-link shrink-0 !px-4 !py-1.5 text-teal border border-teal/20 bg-teal/5 hover:bg-teal/10">
            Try it live ↗
          </a>
        )}
      </div>
      <time class="mt-6 block text-sm font-medium uppercase tracking-[0.18em] text-slate-400" datetime={date.toISOString()}>
        {formattedDate}
      </time>
    </header>

    <div class="prose max-w-none">
      <slot />
    </div>
  </article>
</SiteLayout>
